PORT=4003
MONGO_URL=mongodb://YOUR_DB_USER:YOUR_DB_PASS@127.0.0.1:27017/tracklayer?authSource=admin
REDIS_URL=redis://127.0.0.1:6379
JWT_SECRET=change_this_to_a_long_random_string_min_32_chars

# Optional: only used for country lookup when running on localhost (remove in production)
DEV_TEST_IP=8.8.8.8

# MinIO / S3-compatible storage
MINIO_ENDPOINT=https://your-minio-server.example.com # any s3 bucket URL
MINIO_BUCKET=your-bucket-name
MINIO_ACCESS_KEY=your_access_key
MINIO_SECRET_KEY=your_secret_key
MINIO_CDN_URL=https://cdn.your-domain.com # Optional: if you have a CDN in front of your storage, set this to the CDN URL (e.g. https://cdn.your-domain.com). If not set, the API will return the direct S3 endpoint URL for uploaded files.
