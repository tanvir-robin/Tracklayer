# ── Backend Local Development Environment ───────────────────────────
# For Docker Compose, use the root-level .env.example instead.
# ────────────────────────────────────────────────────────────────────

PORT=4003

# MongoDB — local instance
MONGO_URL=mongodb://localhost:27017/tracklayer

# Redis — local instance
REDIS_URL=redis://localhost:6379

# ⚠️ Change this to a long random string before deploying
JWT_SECRET=change_this_to_a_long_random_string_min_64_chars

# Geo-lookup fallback when request IP is 127.0.0.1 in local dev
DEV_TEST_IP=8.8.8.8

# MinIO / S3-compatible storage
# Quick local MinIO: docker run -p 9000:9000 -p 9001:9001 minio/minio server /data --console-address ":9001"
MINIO_ENDPOINT=http://localhost:9000
MINIO_BUCKET=tracklayer
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
# Optional: CDN URL in front of MinIO (leave blank for local dev)
MINIO_CDN_URL=
