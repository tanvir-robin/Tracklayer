# ────────────────────────────────────────────────────────────────────
#  TrackLayer — Environment Variables
#  Copy this file to .env and fill in the values marked ⚠️
# ────────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────────
PORT=4003

# ⚠️  Change this to a long random string before deploying
JWT_SECRET=change_this_to_a_long_random_secret_at_least_64_chars

# ── MinIO / S3 storage ───────────────────────────────────────────────
# When running via Docker Compose these defaults just work.
# If you have an external S3 bucket, replace all MINIO_* values.
MINIO_ENDPOINT=http://minio:9000
MINIO_BUCKET=tracklayer
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
# Optional: CDN URL in front of MinIO (e.g. https://cdn.example.com)
MINIO_CDN_URL=

# ── Geo-lookup fallback (local dev only) ─────────────────────────────
# Used when the request IP is 127.0.0.1 (not needed in Docker/production)
DEV_TEST_IP=8.8.8.8

# ── Frontend build arg (Docker only) ─────────────────────────────────
# Leave as "/" when using Docker Compose — nginx routes API calls on the same host.
# Set to your full API URL only if the frontend and API are on different domains.
VITE_API_BASE=/
